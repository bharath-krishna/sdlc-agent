# Application settings
APP_NAME="Doll Shop API"
APP_VERSION="1.0.0"
DEBUG="false"
API_V1_PREFIX="/api/v1"

# Database settings
DATABASE_URL="postgresql+asyncpg://postgres:postgres@db:5432/doll_shop"

# JWT settings
SECRET_KEY="your-secret-key-change-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS settings
CORS_ORIGINS="http://localhost:3000,http://localhost:8080"